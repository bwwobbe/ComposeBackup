{
  "Settings": {
    "BatchMinutes": 5,
    "ComposeDirectory": "/opt/stacks",
    "DryRun": false,
    "Backups": {
      "/data/backup1": {
        "when": "0 0 * * 7",
        "keep": {
          "days": 4
        }
      },
      "/data/backup2": {
        "when": "0 0 * * 4",
        "keep": {
          "days": 4
        }
      },
      "/data/backup3": {
        "when": "@daily",
        "keep": {
          "days": 4
        }
      },
      "/data/minutely": {
        "when": "* * * * *",
        "keep": {
          "days": 4
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
